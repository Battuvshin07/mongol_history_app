# ============================================
# Environment Configuration
# Copy this file to .env and fill in your values
# ============================================

# Server
NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb://localhost:27017/mongol_history_db

# JWT
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRE=7d

# CORS - Flutter app URL (adjust for your setup)
CLIENT_URL=*

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─────────────────────────────────────────────────────────────────
# Firebase Admin SDK
# ─────────────────────────────────────────────────────────────────
# Place your service account JSON at: backend/keys/serviceAccountKey.json
# Download from: Firebase Console → Project Settings → Service Accounts
#                → Generate new private key
# The `keys/` directory is in .gitignore – NEVER commit this file.
